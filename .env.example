# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Telegram Bot API (sending matched jobs to output channel) ─────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_OUTPUT_CHANNEL_ID=-100your_channel_id

# ── Telegram User Account / TDLib (reading subscribed channels) ───────────────
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE_NUMBER=+1234567890

# ── AI — Google Gemini ─────────────────────────────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.1

# ── AI pipeline behaviour ──────────────────────────────────────────────────────
# Set APP_AI_PROVIDER=mock to use mock provider without an API key
APP_AI_ENABLED=true
APP_AI_PROVIDER=gemini
APP_AI_MIN_RULE_SCORE=7
APP_AI_MIN_QUALIFICATION_SCORE=80
APP_AI_MAX_DESCRIPTION_CHARS=12000
APP_AI_REQUIRE_URL_ENRICHMENT=false
APP_AI_REQUIRE_HUMAN_APPROVAL=true
APP_AI_STORE_RAW_PROMPTS=true
APP_AI_SEND_CV_TO_AI=false

# ── URL enrichment ─────────────────────────────────────────────────────────────
APP_URL_ENRICHMENT_ENABLED=true
APP_URL_MAX_NESTED_LINKS=0
APP_URL_ENRICHMENT_TIMEOUT_SECONDS=15
APP_URL_MAX_PAGE_CHARS=20000
APP_URL_ALLOWED_DOMAINS_ONLY=false
