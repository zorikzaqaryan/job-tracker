# ── Secrets & local config ────────────────────────────────────────────────────
.env
*.env.local

# ── Maven build output ────────────────────────────────────────────────────────
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ── TDLib runtime data (user session, downloaded files) ──────────────────────
tdlib-db/
tdlib-files/

# ── IDE: IntelliJ IDEA ───────────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
out/

# ── IDE: VS Code / Cursor ────────────────────────────────────────────────────
.vscode/
*.code-workspace

# ── IDE: Eclipse ─────────────────────────────────────────────────────────────
.eclipse/
.classpath
.project
.settings/
.factorypath

# ── OS generated files ────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
spring.log

# ── Docker local data volumes (if ever bind-mounted locally) ─────────────────
docker-data/

# ── Monitoring: runtime state (Docker volumes, not config) ───────────────────
# Provisioning config and dashboards ARE committed (monitoring/grafana/, monitoring/prometheus/)
# Only ignore runtime/state directories if you ever bind-mount them locally.
monitoring/grafana/data/
monitoring/prometheus/data/

# ── Java ─────────────────────────────────────────────────────────────────────
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*
